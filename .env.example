# ---------------------------------------------------------------------------
# RevEd backend — environment template
#
# 1. Copy this file to `.env` in the same directory:        cp .env.example .env
# 2. Fill in every value marked `your_...` with a real secret.
# 3. NEVER commit `.env`. Only `.env.example` belongs in version control.
# 4. For production, set ENVIRONMENT=production and AUTH_ENABLED=true.
#    The app refuses to start if ENVIRONMENT=production while AUTH_ENABLED=false.
# ---------------------------------------------------------------------------

# `development` | `staging` | `production`. Controls strict startup checks.
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

HUGGINGFACE_API_KEY=your_huggingface_api_key
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_EMBEDDING_BATCH_SIZE=16
HF_EMBEDDING_NORMALIZE=true

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.1
GROQ_MAX_COMPLETION_TOKENS=700
# Model used for the preflight question correction, clarity-check, and
# educational-intent judgment in the student tutor. Defaults to the same
# top-tier model used for answers — preflight quality directly affects
# whether legitimate student follow-ups are allowed through.
GROQ_PREFLIGHT_MODEL=llama-3.3-70b-versatile
GROQ_PREFLIGHT_MAX_TOKENS=500

PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=reved-index
PINECONE_DIMENSION=384
PINECONE_METRIC=cosine
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=textbooks
PINECONE_UPSERT_BATCH_SIZE=100
PINECONE_INCLUDE_CHUNK_TEXT=false

# Supabase Postgres (use the transaction pooler URL on port 6543).
# URL-encode special characters in the password (# -> %23, / -> %2F, @ -> %40).
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Supabase project keys
SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
SUPABASE_JWT_ALGORITHM=HS256
SUPABASE_JWT_AUDIENCE=authenticated

# When true, routes require a verified Supabase JWT. When false (default),
# routes accept requests without a token and inject a stub user context.
AUTH_ENABLED=false

# Cache backend: 'memory' (default, in-process) or 'redis'.
CACHE_BACKEND=memory
CACHE_DEFAULT_TTL_SECONDS=300
REDIS_URL=

# --- Tiered rate limits ----------------------------------------------------
# LLM endpoints (POST /student/ask, /teacher/*, /parent/explain-topic) are
# capped per caller. The cap depends on the caller's subscription tier,
# resolved from a verified JWT claim (`subscription_tier` / `tier`) in
# production, or the `X-Dev-Tier` header in dev (AUTH_ENABLED=false).
#
# Tier assumed when a token carries no tier claim. Most restrictive on
# purpose — an un-provisioned token never gets paid limits by accident.
RATE_LIMIT_DEFAULT_TIER=free
# Optional overrides layered on the built-in defaults
# (free:10/minute, basic:20/minute, premium:60/minute, unlimited:1000/minute).
# Format: comma-separated `tier:limit`, limits are slowapi expressions
# (`;`-separate multiple windows, e.g. premium:60/minute;5000/hour).
# Leave blank to use the built-in defaults.
RATE_LIMIT_LLM_TIERS=
