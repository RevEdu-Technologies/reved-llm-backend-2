{
  "title": "RevEd backend — overview",
  "description": "Request rate, error rate, p95 latency, LLM spend proxy, auth events. Import into Grafana via Dashboards → New → Import.",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["reved", "backend"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (req/s) by handler",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler!=\"/metrics\"}[1m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (5xx as % of total) by handler",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (handler) / clamp_min(sum(rate(http_requests_total[5m])) by (handler), 0.001)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p95 latency by handler",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "LLM token spend rate (tokens/s) by model + kind",
      "description": "Proxy for Groq spend. Multiply by your per-token unit cost in the dashboard variables to get $/min.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(reved_llm_tokens_total[5m])) by (model, kind)",
          "legendFormat": "{{model}} / {{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Auth events / min by outcome",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "60 * sum(rate(reved_auth_events_total[1m])) by (event, outcome)",
          "legendFormat": "{{event}} {{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Rate-limit hits / min",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "60 * sum(rate(http_requests_total{status=\"429\"}[5m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
