# Logs / local artefacts
*.log
uvicorn.err.log
uvicorn.out.log

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code per-project harness state
.claude/

# Data / models / notebook checkpoints (large local-only files)
# NOTE: leading `/` anchors to repo root so we don't accidentally match
# `app/models/` (ORM layer) — that's tracked code, not ML weight artefacts.
/data/
/models/
notebooks/.ipynb_checkpoints/
